# =============================================================================
# Server-side only (BFF). NEVER prefix with NEXT_PUBLIC_ — these stay on server.
# =============================================================================

# auth_service base URL
#   Local (host machine):  http://localhost:8008/api/v1
#   Inside docker network: http://auth_webserver:8000/api/v1
AUTH_SERVICE_URL=http://localhost:8008/api/v1

# test_api base URL (the business API; you will create this service)
#   Local (host machine):  http://localhost:8009/api/v1
#   Inside docker network: http://test_api_webserver:8000/api/v1
TEST_API_URL=http://localhost:8009/api/v1

# Cookie name for the HttpOnly refresh_token cookie set by BFF.
AUTH_REFRESH_COOKIE_NAME=rt

# Cookie domain (leave blank for current host in dev).
AUTH_COOKIE_DOMAIN=

# In dev, cookies must NOT be Secure (no HTTPS). Phase 6 will harden for prod.
AUTH_COOKIE_SECURE=false

# Outbound HTTP timeout for BFF -> upstream (ms)
UPSTREAM_TIMEOUT_MS=20000

# =============================================================================
# Public (exposed to the browser bundle). Prefix with NEXT_PUBLIC_.
# =============================================================================
NEXT_PUBLIC_APP_NAME=test_frontend
